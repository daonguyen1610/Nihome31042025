{
  "_comment": "RBAC seed data. Loaded once at startup by RbacSeedData. Permission and role label keys follow the conventions rbac.perm.{module}.{action} and rbac.role.{CODE}.{label|description} — no need to repeat them here. Patterns support * (one dot-segment) and ** (any segments). The 'deny' list is subtracted from the expanded matches.",

  "baseCatalog": [
    { "module": "dashboard", "action": "view" },

    { "module": "system.audit", "action": "view" },
    { "module": "system.audit", "action": "manage" },
    { "module": "system.notifications", "action": "manage" },
    { "module": "system.uploads", "action": "manage" },

    { "module": "users", "action": "view" },
    { "module": "users", "action": "manage" },
    { "module": "rbac.roles", "action": "view" },
    { "module": "rbac.roles", "action": "manage" },

    { "module": "profile.me", "action": "view" },
    { "module": "profile.me", "action": "update" },

    { "module": "content.about", "action": "view" },
    { "module": "content.about", "action": "manage" },
    { "module": "content.activities", "action": "view" },
    { "module": "content.activities", "action": "manage" },
    { "module": "content.activity-categories", "action": "view" },
    { "module": "content.activity-categories", "action": "manage" },
    { "module": "content.logos", "action": "view" },
    { "module": "content.logos", "action": "manage" },
    { "module": "content.news", "action": "view" },
    { "module": "content.news", "action": "manage" },
    { "module": "content.projects", "action": "view" },
    { "module": "content.projects", "action": "manage" },
    { "module": "content.project-categories", "action": "view" },
    { "module": "content.project-categories", "action": "manage" },
    { "module": "content.services", "action": "view" },
    { "module": "content.services", "action": "manage" },
    { "module": "content.slideshow", "action": "view" },
    { "module": "content.slideshow", "action": "manage" },

    { "module": "processes", "action": "view" },
    { "module": "processes", "action": "manage" },
    { "module": "processes.uploads", "action": "manage" },

    { "module": "mail", "action": "send" },

    { "module": "contacts", "action": "view" },
    { "module": "contacts", "action": "manage" },

    { "module": "recruitment.applications", "action": "view" },
    { "module": "recruitment.applications", "action": "manage" },
    { "module": "recruitment.positions", "action": "view" },
    { "module": "recruitment.positions", "action": "manage" },
    { "module": "recruitment.options", "action": "view" },
    { "module": "recruitment.options", "action": "manage" }
  ],

  "businessRoles": [
    { "code": "SALE", "name": "Sale" },
    { "code": "DESIGN", "name": "Design" },
    { "code": "PM", "name": "Project Manager" },
    { "code": "QS", "name": "Quantity Surveyor" },
    { "code": "ACCOUNTANT", "name": "Accountant" },
    { "code": "WAREHOUSE", "name": "Warehouse" },
    { "code": "BGD", "name": "Board of Directors" }
  ],

  "rolePermissions": {
    "SUPER_ADMIN": { "patterns": ["**"] },
    "ADMIN":       { "patterns": ["**"], "deny": ["users.manage", "system.audit.manage"] },
    "USER":        { "patterns": ["profile.me.*"] },

    "SALE": {
      "patterns": ["dashboard.view", "contacts.*", "recruitment.applications.view", "profile.me.*"]
    },
    "DESIGN": {
      "patterns": ["dashboard.view", "content.**", "processes.view", "profile.me.*"]
    },
    "PM": {
      "patterns": ["dashboard.view", "content.projects.*", "processes.*", "recruitment.applications.view", "profile.me.*"]
    },
    "QS": {
      "patterns": ["dashboard.view", "content.projects.view", "processes.view", "profile.me.*"]
    },
    "ACCOUNTANT": {
      "patterns": ["dashboard.view", "contacts.view", "system.audit.view", "profile.me.*"]
    },
    "WAREHOUSE": {
      "patterns": ["dashboard.view", "processes.view", "profile.me.*"]
    },
    "BGD": {
      "patterns": ["dashboard.view", "**.view", "system.audit.view", "profile.me.*"]
    }
  }
}
