# Ignore backend build artifacts
nihomebackend/bin/**
nihomebackend/obj/**
# Ignore publish folder since we will generate it from the source code and deploy to hosting
nihomebackend/publish
nihomebackend/bin/
nihomebackend/obj/
nihomebackend.tests/bin/**
nihomebackend.tests/obj/**
.amazonq
.agents
skills-lock.json
# Deployment config
deployment-config/output/publish-release/
deployment-config/output/publish-release.zip
nihomebackend.integration.tests/bin/
nihomebackend.integration.tests/obj/
TestResults/

# Backend wwwroot is reserved for backend-managed static assets only
# (user-uploaded images, CVs, process-assets). The React SPA is built to
# nihomeweb/dist and served via WebRootPath — never copy dist/* here.
nihomebackend/wwwroot/index.html
nihomebackend/wwwroot/favicon.svg
nihomebackend/wwwroot/assets/
